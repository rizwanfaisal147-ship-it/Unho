\par
  <!-- scripts -->\par
  <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/build/three.min.js"></script>\par
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>\par
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>\par
  <script>\par
    (function() \{\par
      // register scrolltrigger\par
      gsap.registerPlugin(ScrollTrigger);\par
\par
      // ----- THREE.JS particles (premium dark gold + pink) -----\par
      const canvas = document.getElementById('bg-canvas');\par
      const scene = new THREE.Scene();\par
      scene.background = new THREE.Color(0x0b0a0c);\par
      const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);\par
      camera.position.z = 30;\par
      const renderer = new THREE.WebGLRenderer(\{ canvas, alpha: false, antialias: true \});\par
      renderer.setSize(window.innerWidth, window.innerHeight);\par
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));\par
\par
      const geometry = new THREE.BufferGeometry();\par
      const count = 2000;\par
      const positions = new Float32Array(count * 3);\par
      const colors = new Float32Array(count * 3);\par
      for (let i = 0; i < count; i++) \{\par
        let r = (Math.random() - 0.5) * 60;\par
        let x = (Math.random() - 0.5) * 80;\par
        let y = (Math.random() - 0.5) * 80;\par
        let z = (Math.random() - 0.5) * 60;\par
        positions[i*3] = x; positions[i*3+1] = y; positions[i*3+2] = z;\par
        // gold / soft pink colors\par
        let color = new THREE.Color().setHSL(0.08 + Math.random()*0.1, 0.8, 0.6 + Math.random()*0.3);\par
        colors[i*3] = color.r; colors[i*3+1] = color.g; colors[i*3+2] = color.b;\par
      \}\par
      geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));\par
      geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));\par
      const material = new THREE.PointsMaterial(\{ size: 0.2, vertexColors: true, transparent: true, opacity: 0.7, blending: THREE.AdditiveBlending \});\par
      const particles = new THREE.Points(geometry, material);\par
      scene.add(particles);\par
\par
      function animateParticles() \{\par
        requestAnimationFrame(animateParticles);\par
        particles.rotation.y += 0.0001;\par
        particles.rotation.x += 0.00005;\par
        renderer.render(scene, camera);\par
      \}\par
      animateParticles();\par
\par
      window.addEventListener('resize', () => \{\par
        camera.aspect = window.innerWidth / window.innerHeight;\par
        camera.updateProjectionMatrix();\par
        renderer.setSize(window.innerWidth, window.innerHeight);\par
      \});\par
\par
      // intro logic (music removed)\par
      const intro = document.getElementById('introScreen');\par
      const main = document.getElementById('mainContent');\par
      const enterBtn = document.getElementById('enterBtn');\par
\par
      enterBtn.addEventListener('click', () => \{\par
        gsap.to(intro, \{ opacity: 0, duration: 1.5, ease: 'power2.inOut', onComplete: () => \{\par
          intro.style.display = 'none';\par
          main.style.opacity = 1;\par
        \}\});\par
      \});\par
\par
      // typewriter effect\par
      const message = `I remember the first time we spoke \f3\emdash  the world felt lighter. \par
Every moment with you is a page from a fairytale I never want to end. \par
You have a way of making ordinary days feel extraordinary. \par
And today, the universe celebrates the masterpiece that is you. \f1\u-10179?\u-9045?\f0 `;\par
\par
      const container = document.getElementById('typewriterContainer');\par
      let i = 0;\par
      function typeNext() \{\par
        if (i < message.length) \{\par
          container.innerHTML += message.charAt(i) === '\\n' ? '<br/>' : message.charAt(i);\par
          i++;\par
          setTimeout(typeNext, 50);\par
        \} else \{\par
          // add glowing words after\par
          container.innerHTML = container.innerHTML.replace('fairytale', '<span class="glow-word">fairytale</span>');\par
          container.innerHTML = container.innerHTML.replace('masterpiece', '<span class="glow-word">masterpiece</span>');\par
        \}\par
      \}\par
      // start typewriter when in view (approx)\par
      gsap.timeline(\{\par
        scrollTrigger: \{\par
          trigger: '#typewriterContainer',\par
          start: 'top 80%',\par
          onEnter: () => \{ if(i===0) typeNext(); \}\par
        \}\par
      \});\par
\par
      // sparkles hero\par
      setInterval(() => \{\par
        let heart = document.createElement('span');\par
        heart.className = 'floating-heart';\par
        heart.innerHTML = ['\f2\u10024?\f0 ','\f1\u-10179?\u-9066?\f0 ','\f1\u-10180?\u-8417?\f0 ','\f1\u-10180?\u-8318?\f0 ','\f1\u-10179?\u-8700?\f0 '][Math.floor(Math.random()*5)];\par
        heart.style.left = Math.random() * 100 + '%';\par
        heart.style.top = Math.random() * 100 + '%';\par
        heart.style.animation = `float $\{3+Math.random()*4\}s linear`;\par
        heart.style.opacity = 0.8;\par
        document.getElementById('hero').appendChild(heart);\par
        setTimeout(() => heart.remove(), 4000);\par
      \}, 400);\par
\par
      // interactive cake\par
      const cake = document.getElementById('cakeContainer');\par
      const wishMsg = document.getElementById('wishMessage');\par
      cake.addEventListener('click', () => \{\par
        cake.classList.add('blow-out');\par
        cake.innerHTML = '\f1\u-10180?\u-8318?\f0 <span style="font-size:4rem;">\f1\u-10179?\u-9048?\f0 </span>';\par
        wishMsg.style.opacity = 1;\par
        // trigger fireworks (soft confetti)\par
        for (let i=0;i<12;i++) \{\par
          let f = document.createElement('div');\par
          f.style.position = 'fixed'; f.style.left='50%'; f.style.top='50%';\par
          f.style.color = '#e5c687'; f.style.fontSize='2rem'; f.style.pointerEvents='none';\par
          f.innerHTML = ['\f2\u10024?\f0 ','\f1\u-10180?\u-8311?\f0 ','\f1\u-10179?\u-9051?\f0 ','\f1\u-10180?\u-8417?\f0 '][Math.floor(Math.random()*4)];\par
          f.style.zIndex = 9999;\par
          document.body.appendChild(f);\par
          gsap.to(f, \{ x: (Math.random()-0.5)*400, y: (Math.random()-0.5)*400, opacity:0, duration:2, ease:'power2.out', onComplete:()=>f.remove() \});\par
        \}\par
      \});\par
\par
      // secret modal\par
      const secretTrigger = document.getElementById('secretTrigger');\par
      const secretModal = document.getElementById('secretModal');\par
      const closeSecret = document.getElementById('closeSecret');\par
      secretTrigger.addEventListener('click', () => secretModal.classList.add('show'));\par
      closeSecret.addEventListener('click', () => secretModal.classList.remove('show'));\par
      secretModal.addEventListener('click', (e) => \{ if(e.target === secretModal) secretModal.classList.remove('show'); \});\par
\par
      // final wishes soft fade-out effect? (we just add a subtle entrance)\par
      gsap.from('#finalWishes .glass-card', \{ scrollTrigger: '#finalWishes', scale: 0.8, opacity: 0, duration: 1.5 \});\par
\par
      // floating sparkles on final section\par
      setInterval(() => \{\par
        let sp = document.createElement('span');\par
        sp.innerHTML = '\f2\u10024?\f0 '; sp.style.position='absolute'; sp.style.left=Math.random()*100+'%'; sp.style.top=Math.random()*100+'%';\par
        sp.style.fontSize='2rem'; sp.style.opacity=0.6; sp.style.pointerEvents='none';\par
        sp.style.animation = 'float 5s infinite';\par
        document.getElementById('finalWishes').appendChild(sp);\par
        setTimeout(() => sp.remove(), 5000);\par
      \}, 500);\par
\par
      // add keyframe style\par
      const styleSheet = document.createElement("style");\par
      styleSheet.textContent = `@keyframes float \{ 0% \{ transform: translateY(0) rotate(0deg); opacity:0.6; \} 100% \{ transform: translateY(-120px) rotate(20deg); opacity:0; \} \}`;\par
      document.head.appendChild(styleSheet);\par
\par
      // editable wish (double-click to edit)\par
      const wishP = document.getElementById('editableWish');\par
      wishP.addEventListener('dblclick', () => \{\par
        wishP.contentEditable = true;\par
        wishP.focus();\par
      \});\par
      wishP.addEventListener('blur', () => wishP.contentEditable = false);\par
    \})();\par
  </script>\par
\par
  <!-- ensure smooth scroll, some extra sparkles in hero -->\par
  <style>\par
    html \{ scroll-behavior: smooth; \}\par
    ::selection \{ background: #e5c687; color: #0b0a0c; \}\par
  </style>\par
</body>\par
</html>\par
